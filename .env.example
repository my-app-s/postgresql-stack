# =====================================================================
# PostgreSQL + pgAdmin + Traefik Configuration Template
# =====================================================================

# Uncomment only what you need.

# --- Image versions ---
# PostgreSQL image version
#VERSION=latest

# --- Service ports (internal) ---
# PostgreSQL internal port
#HOST_PORT_P=5432

# pgAdmin internal port
#HOST_PORT_PG=80

# --- Traefik Integration (disabled by default) ---
# Enable Traefik routing (true / false)
#TRAEFIK_ENABLED=false

# --- Local / Development Mode ---
# Used when running without Traefik
#DOMAIN=localhost
#CERT_RESOLVER=

# --- Production Mode (Traefik enabled) ---
# Enable public HTTPS access via Traefik

#TRAEFIK_ENABLED=true

# Your domain (must point to server)
#DOMAIN=your-domain.com

# Traefik certificate resolver (e.g. myresolver)
#CERT_RESOLVER=myresolver

# Use external Traefik network
#TRAEFIK_NETWORK_EXTERNAL=true

# Name of existing Traefik network
#TRAEFIK_NETWORK_NAME=traefik_public_network