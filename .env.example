# ==============================================================================
# PostgreSQL + pgAdmin + Traefik Configuration Template
# ==============================================================================
# Раскомментируйте и заполните только те параметры, которые необходимо изменить.
# По умолчанию стек готов к локальной разработке.

# ------------------------------------------------------------------------------
# --- Container Image Versions / Версии образов ---
# ------------------------------------------------------------------------------
# Optional: Pin specific versions. If commented out, Docker defaults to 'latest'.
# Опционально: Укажите конкретные версии. Если закомментировано, используется 'latest'.
#VERSION_P=16-alpine
#VERSION_PG=8.5

# ------------------------------------------------------------------------------
# --- Local Service Ports / Локальные порты хоста ---
# ------------------------------------------------------------------------------
# Optional: Change host ports if defaults (5432 / 8080) are already occupied.
# Note: HOST_PORT_PG is only used for direct access without Traefik.
# Опционально: Измените порты, если стандартные (5432 / 8080) уже заняты на сервере.
# Примечание: HOST_PORT_PG нужен только для прямого доступа к pgAdmin в обход Traefik.
#HOST_PORT_P=5432
#HOST_PORT_PG=8080

# ------------------------------------------------------------------------------
# --- Production & Reverse Proxy Mode (Traefik) ---
# ------------------------------------------------------------------------------

# Enable routing via Traefik (true/false). If false, use docker-compose.override.yml ports.
# Включить маршрутизацию через Traefik. Если false, используйте порты в override файле.
#TRAEFIK_ENABLED=true

# Your public domain name (must point to the server IP). Leave empty for localhost.
# Ваше доменное имя (должно указывать на IP сервера). Оставьте пустым для localhost.
#DOMAIN=example.com

# Name of the certificate resolver configured in Traefik (e.g., 'myresolver').
# Leave empty to use Traefik's default self-signed certificate (for local testing).
# Имя резолвера сертификатов, настроенного в Traefik (например, 'myresolver').
# Оставьте пустым для использования дефолтного самоподписанного сертификата.
#CERT_RESOLVER=myresolver

# Name of the Docker network that Traefik uses to route traffic.
# Название Docker-сети, которую Traefik использует для маршрутизации трафика.
#TRAEFIK_NETWORK_NAME=traefik_public_network

# Set to true if the Traefik network already exists externally (created outside this stack).
# Укажите true, если сеть Traefik уже создана в системе внешним образом.
#TRAEFIK_NETWORK_EXTERNAL=true